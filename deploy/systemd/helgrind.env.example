# Helgrind systemd environment override example
# Copy to /etc/helgrind/helgrind.env and adjust as needed.

ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Public proxy listener exposed outside your network.
Helgrind__PublicHttpsPort=443

# Admin listener kept private to LAN/VPN only.
Helgrind__AdminHttpsPort=8444

# Persist database and uploaded certificates outside the app directory.
Helgrind__DatabasePath=/var/lib/helgrind/helgrind.db
Helgrind__CertificateStoragePath=/var/lib/helgrind/certificates

# Default deployment locations used by install.sh and update.sh.
HELGRIND_SOURCE_DIR=/opt/helgrind-src
HELGRIND_INSTALL_DIR=/opt/helgrind
HELGRIND_REPO_URL=https://github.com/Jeffe747/Helgrind.git
HELGRIND_REPO_REF=main

# Optional explicit production self-update command override.
# When omitted, Helgrind will use /opt/helgrind/deploy/linux/update.sh automatically if it exists.
# Helgrind__SelfUpdateCommand=sudo /bin/bash /opt/helgrind/deploy/linux/update.sh
Helgrind__SelfUpdateWorkingDirectory=/opt/helgrind-src

# Default LAN-only CIDR policy for the admin listener.
# Add VPN or overlay network ranges here when needed.
Helgrind__AllowedAdminNetworks__0=127.0.0.0/8
Helgrind__AllowedAdminNetworks__1=::1/128
Helgrind__AllowedAdminNetworks__2=10.0.0.0/8
Helgrind__AllowedAdminNetworks__3=172.16.0.0/12
Helgrind__AllowedAdminNetworks__4=192.168.0.0/16
Helgrind__AllowedAdminNetworks__5=fc00::/7
Helgrind__AllowedAdminNetworks__6=fe80::/10

# Example VPN ranges:
# Helgrind__AllowedAdminNetworks__7=100.64.0.0/10
# Helgrind__AllowedAdminNetworks__8=fd7a:115c:a1e0::/48

# Telemetry defaults. Suspicious public traffic is retained for 30 days.
# Helgrind__TelemetryEnabled=true
# Helgrind__TelemetryRetentionDays=30
# Helgrind__TelemetryBurstWindowSeconds=30
# Helgrind__TelemetryBurstThreshold=20
# Helgrind__TelemetrySmokePath=/__helgrind/telemetry/smoke

# Optional webhook alerting for high-risk telemetry events.
# Set this to a Discord webhook or another endpoint that accepts {"content":"..."} JSON.
# Helgrind__TelemetryAlertWebhookUrl=https://discord.com/api/webhooks/...
# Helgrind__TelemetryAlertMinimumRiskScore=3
# Helgrind__TelemetryAlertCooldownMinutes=10