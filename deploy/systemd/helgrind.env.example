# Helgrind systemd environment override example
# Copy to /etc/helgrind/helgrind.env and adjust as needed.

ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Public proxy listener exposed outside your network.
Helgrind__PublicHttpsPort=443

# Admin listener kept private to LAN/VPN only.
Helgrind__AdminHttpsPort=8444

# Persist database and uploaded certificates outside the app directory.
Helgrind__DatabasePath=/var/lib/helgrind/helgrind.db
Helgrind__CertificateStoragePath=/var/lib/helgrind/certificates

# Default LAN-only CIDR policy for the admin listener.
# Add VPN or overlay network ranges here when needed.
Helgrind__AllowedAdminNetworks__0=127.0.0.0/8
Helgrind__AllowedAdminNetworks__1=::1/128
Helgrind__AllowedAdminNetworks__2=10.0.0.0/8
Helgrind__AllowedAdminNetworks__3=172.16.0.0/12
Helgrind__AllowedAdminNetworks__4=192.168.0.0/16
Helgrind__AllowedAdminNetworks__5=fc00::/7
Helgrind__AllowedAdminNetworks__6=fe80::/10

# Example VPN ranges:
# Helgrind__AllowedAdminNetworks__7=100.64.0.0/10
# Helgrind__AllowedAdminNetworks__8=fd7a:115c:a1e0::/48